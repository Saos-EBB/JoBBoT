{
  "name": "jobbot",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "tsx scripts/check-ollama.ts",
    "smoke": "tsx scripts/smoke-storage.ts",
    "dev": "tsx run.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-reporter spec",
    "test:watch": "node --import tsx --test --watch --test-reporter spec",
    "recon:karriere": "tsx scripts/recon-karriere.ts",
    "filter": "tsx scripts/run-filter.ts",
    "filter:regex": "tsx scripts/run-filter.ts --filter=regex",
    "scrape": "tsx scripts/run-scrape.ts",
    "scrape:karriere": "tsx scripts/run-scrape.ts --source=karriere",
    "scrape:devjobs": "tsx scripts/run-scrape.ts --source=devjobs",
    "scrape:linkedin": "tsx scripts/run-scrape.ts --source=linkedin",
    "scrape:ams": "tsx scripts/run-scrape.ts --source=ams",
    "scrape:jobs": "tsx scripts/run-scrape.ts --source=jobs",
    "anschreiben": "tsx scripts/run-anschreiben.ts",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.61.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
